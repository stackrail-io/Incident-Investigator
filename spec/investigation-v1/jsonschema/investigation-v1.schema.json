{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stackrail.io/investigation-spec/v1/investigation.schema.json",
  "title": "Investigation",
  "description": "Investigation Specification v1 — core investigation resource",
  "type": "object",
  "required": ["investigation_id", "question", "state", "evidence", "hypotheses", "confidence"],
  "properties": {
    "investigation_id": { "type": "string", "description": "Alias: session_id in reference MCP binding" },
    "session_id": { "type": "string", "deprecated": true },
    "question": { "type": "string", "minLength": 1 },
    "service": { "type": "string" },
    "goal": { "$ref": "#/$defs/InvestigationGoal" },
    "time_window": { "$ref": "#/$defs/TimeWindow" },
    "state": { "$ref": "#/$defs/InvestigationState" },
    "status": { "$ref": "#/$defs/LegacyStatus" },
    "plan": { "$ref": "#/$defs/InvestigationPlan" },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/Evidence" } },
    "required_evidence": { "type": "array", "items": { "$ref": "#/$defs/EvidenceRequest" } },
    "missing_evidence": { "type": "array", "items": { "$ref": "#/$defs/EvidenceRequest" } },
    "graph": { "$ref": "#/$defs/GraphView" },
    "hypotheses": { "type": "array", "items": { "$ref": "#/$defs/Hypothesis" } },
    "findings": { "type": "array", "items": { "$ref": "#/$defs/Finding" } },
    "recommendations": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "progress": { "type": "number", "minimum": 0, "maximum": 100 },
    "sufficiency": { "$ref": "#/$defs/SufficiencyReport" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "EvidenceCategory": {
      "type": "string",
      "enum": [
        "application_logs", "infrastructure_events", "deployment_events", "alert_events",
        "metrics", "trace_events", "configuration_changes", "network_events",
        "database_events", "security_events", "human_context", "custom"
      ]
    },
    "Priority": { "type": "string", "enum": ["high", "medium", "low"] },
    "InvestigationGoal": {
      "type": "string",
      "enum": [
        "root_cause", "timeline", "blast_radius", "deployment_verification",
        "performance_regression", "availability", "custom"
      ]
    },
    "InvestigationState": {
      "type": "string",
      "enum": [
        "started", "planning", "collecting_evidence", "reasoning",
        "waiting_for_evidence", "high_confidence", "completed", "failed"
      ]
    },
    "LegacyStatus": {
      "type": "string",
      "enum": ["collecting_evidence", "ready_to_conclude", "completed"]
    },
    "InvestigationStage": {
      "type": "string",
      "enum": [
        "planning", "question_generation", "evidence_collection", "question_resolution",
        "hypothesis_evaluation", "need_more_evidence", "completed"
      ]
    },
    "QuestionStatus": {
      "type": "string",
      "enum": ["unknown", "waiting_for_evidence", "partially_answered", "answered", "rejected"]
    },
    "HypothesisStatus": {
      "type": "string",
      "enum": ["proposed", "supported", "leading", "refuted", "confirmed"]
    },
    "TimeWindow": {
      "type": "object",
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      }
    },
    "Evidence": {
      "type": "object",
      "required": ["id", "category", "summary"],
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "category": { "$ref": "#/$defs/EvidenceCategory" },
        "source": { "type": "string" },
        "entity": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 },
        "payload": { "type": "object", "additionalProperties": true }
      }
    },
    "EvidenceRequest": {
      "type": "object",
      "required": ["category", "priority"],
      "properties": {
        "category": { "$ref": "#/$defs/EvidenceCategory" },
        "priority": { "$ref": "#/$defs/Priority" },
        "reason": { "type": "string" }
      }
    },
    "ProtocolEvidenceRequest": {
      "type": "object",
      "required": ["id", "question_id", "categories", "priority", "status"],
      "properties": {
        "id": { "type": "string" },
        "question_id": { "type": "string" },
        "categories": { "type": "array", "items": { "$ref": "#/$defs/EvidenceCategory" } },
        "priority": { "$ref": "#/$defs/Priority" },
        "reason": { "type": "string" },
        "expected_confidence_gain": { "type": "number", "minimum": 0, "maximum": 100 },
        "status": { "type": "string", "enum": ["open", "fulfilled"] }
      }
    },
    "Question": {
      "type": "object",
      "required": ["id", "title", "status"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "integer" },
        "status": { "$ref": "#/$defs/QuestionStatus" },
        "confidence": { "type": "number" },
        "required_evidence": { "type": "array", "items": { "$ref": "#/$defs/EvidenceCategory" } },
        "depends_on": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Hypothesis": {
      "type": "object",
      "required": ["id", "statement", "confidence", "status"],
      "properties": {
        "id": { "type": "string" },
        "statement": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "status": { "$ref": "#/$defs/HypothesisStatus" },
        "rationale": { "type": "string" },
        "supporting_evidence": { "type": "array", "items": { "type": "string" } },
        "conflicting_evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Finding": {
      "type": "object",
      "required": ["type", "summary"],
      "properties": {
        "type": { "type": "string" },
        "summary": { "type": "string" },
        "confidence": { "type": "number" },
        "reason": { "type": "string" },
        "refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "InvestigationPlan": {
      "type": "object",
      "required": ["id", "goal", "current_stage", "questions"],
      "properties": {
        "id": { "type": "string" },
        "goal": { "$ref": "#/$defs/InvestigationGoal" },
        "current_stage": { "$ref": "#/$defs/InvestigationStage" },
        "questions": { "type": "array", "items": { "$ref": "#/$defs/Question" } },
        "evidence_requests": { "type": "array", "items": { "$ref": "#/$defs/ProtocolEvidenceRequest" } },
        "confidence": { "type": "number" }
      }
    },
    "SufficiencyReport": {
      "type": "object",
      "required": ["can_answer", "overall_confidence"],
      "properties": {
        "can_answer": { "type": "boolean" },
        "overall_confidence": { "type": "number" },
        "coverage": { "type": "number" },
        "reason": { "type": "string" }
      }
    },
    "GraphNode": {
      "type": "object",
      "required": ["id", "type", "label"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "label": { "type": "string" },
        "ref_id": { "type": "string" }
      }
    },
    "GraphEdge": {
      "type": "object",
      "required": ["id", "from", "to", "type", "confidence"],
      "properties": {
        "id": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "type": { "type": "string" },
        "confidence": { "type": "number" }
      }
    },
    "GraphView": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/GraphNode" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/GraphEdge" } }
      }
    },
    "Report": {
      "type": "object",
      "required": ["session_id", "question", "executive_summary", "confidence"],
      "properties": {
        "session_id": { "type": "string" },
        "investigation_id": { "type": "string" },
        "question": { "type": "string" },
        "executive_summary": { "type": "string" },
        "confidence": { "type": "number" },
        "hypotheses": { "type": "array", "items": { "$ref": "#/$defs/Hypothesis" } },
        "root_cause_candidates": { "type": "array", "items": { "$ref": "#/$defs/Hypothesis" } },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "postmortem": { "type": "string" },
        "graph": { "$ref": "#/$defs/GraphView" }
      }
    },
    "StartInvestigationRequest": {
      "type": "object",
      "required": ["question"],
      "properties": {
        "question": { "type": "string", "minLength": 1 },
        "service": { "type": "string" },
        "goal": { "$ref": "#/$defs/InvestigationGoal" },
        "time_window": { "$ref": "#/$defs/TimeWindow" }
      }
    },
    "SubmitEvidenceRequest": {
      "type": "object",
      "required": ["evidence"],
      "properties": {
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Evidence" }
        }
      }
    }
  }
}
